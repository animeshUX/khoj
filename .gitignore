.venv/
__pycache__/
*.pyc
# Local-run outputs at repo root (the committed copies live in docs/)
/apartments_*.csv
/apartments_*.html
/sample_report.*
# Local session notes / handoffs — not for the public repo
/session_handoff.md
/SESSION_HANDOFF.md
/.claude/
# Geocode cache — local-only; cron re-fetches on its own runner. Tiny enough
# we could commit it later if Nominatim politeness becomes an issue.
/.cache/
# Web Clipper drops — personal listings, gitignored by default.
# The submissions/ directory is tracked (with its README + .gitkeep) so the
# enrichment pipeline knows where to look; only the .md clips themselves stay
# local unless someone explicitly chooses to track one. ** is recursive — a
# subfolder like submissions/active/ wouldn't be exempt by accident.
/submissions/**/*.md
# Exception: the directory's own README is intake docs, not a clip.
!/submissions/README.md
